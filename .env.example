# Copy this file to .env and fill in your op:// secret references.
# Then run e2e tests with: op run --env-file=.env -- make e2e
#
# The format is: op://<vault>/<item>/<field>
# Examples:
#   op://Personal/GitHub - Personal Access Token/token
#   op://Work/GitHub/token
#   op://Employee/github-pat/credential
#
# To find your exact reference:
#   op item list | grep -i github
#   op item get "GitHub - Personal Access Token" --fields label=token

GH_TOKEN=op://vault/item/token
